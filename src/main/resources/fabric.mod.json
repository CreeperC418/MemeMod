		"main": [
			"com.yekai.meme.MemeMod"
		],
		"client": [
			"com.yekai.meme.MemeModClient"
		],
		"fabric-datagen": [
			"com.yekai.meme.MemeModDataGenerator"
		]
	},
	"mixins": [
